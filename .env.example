# =============================================================================
# ADLC Platform — Variables de entorno (development)
# =============================================================================
# Copia este archivo a `.env` y completa los valores. `.env` está en
# .gitignore — NUNCA lo subas al repo.
#
# En producción los secretos vienen de AWS Secrets Manager. Estas variables
# son solo para desarrollo local.
# =============================================================================

# ---- LLM ----
# Default: claude_cli (usa Claude Max del host via `claude login`, sin API key).
# Alternativa: anthropic (API key paga). Si usas claude_cli, LLM_API_KEY se ignora.
LLM_PROVIDER=claude_cli
LLM_API_KEY=
LLM_MODEL_DEFAULT=claude-opus-4-6
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# ---- Postgres ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=adlc
POSTGRES_USER=adlc
POSTGRES_PASSWORD=adlc_dev_password

# ---- AWS (opcional en dev) ----
AWS_REGION=us-east-1
AWS_PROFILE=default
ADLC_SECRETS_SOURCE=local           # local | aws_secrets_manager

# ---- GitHub ----
GITHUB_TOKEN=ghp_REPLACE_ME
GITHUB_DEFAULT_REPO=owner/repo

# ---- Engine ----
ADLC_CONFIG_PATH=./config/adlc.config.yaml
ADLC_LOG_LEVEL=INFO
ADLC_API_PORT=8000

# ---- API auth (Fase 7 paso 1) ----
# Single-tenant: una API key compartida. Si se setea, todas las rutas
# (salvo /healthz) exigen `Authorization: Bearer <key>` y los WebSocket
# `?api_key=<key>` en query string. La UI guarda la key en localStorage
# del browser y la envia automaticamente.
#
# Generar una key fuerte:  openssl rand -hex 32
#
# Si se deja vacia, la API corre en MODO DEV ABIERTO con un WARNING
# ruidoso al startup. NO usar vacia en produccion ni si la API es
# alcanzable desde internet sin firewall.
ADLC_API_KEY=

# CORS: dominios permitidos separados por coma. Default "*" en dev.
# En produccion restringir a la URL real del deploy de la UI.
# ADLC_CORS_ORIGINS=https://adlc.example.com

# ---- HITL Email (AWS SES) ----
SES_FROM_ADDRESS=adlc@example.com
SES_REGION=us-east-1
